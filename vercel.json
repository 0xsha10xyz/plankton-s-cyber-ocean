{
  "buildCommand": "npm run build:backend && npm run build && npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/[[...path]].ts": {
      "includeFiles": ["api/__backend/**", "api/wallet/**"]
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

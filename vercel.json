{
  "buildCommand": "npm run build:backend && npm run build && npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/[[...path]].ts": {
      "includeFiles": "api/**",
      "runtime": "nodejs20.x"
    },
    "api/health.ts": {
      "runtime": "nodejs20.x"
    },
    "api/wallet/balances.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

{
  "buildCommand": "npm run build:backend && npm run build && npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/**"
    },
    "api/[[...path]].ts": {
      "includeFiles": "api/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

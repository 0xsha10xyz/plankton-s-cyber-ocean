# Vercel serverless / API env (set in Vercel → Settings → Environment Variables)
# Copy to .env only for local testing; do not commit .env

# Required for real-time Swap chart (all pairs, including tokens added by paste CA)
BIRDEYE_API_KEY=

# Optional: RPC for /api/wallet/balances and token-info fallback
SOLANA_RPC_URL=

# Vercel serverless / API env (set in Vercel / Settings / Environment Variables)
# Copy to .env only for local testing; do not commit .env

# Required for real-time Swap chart (all pairs, including tokens added by paste CA)
BIRDEYE_API_KEY=

# Optional: Jupiter quote/swap proxy (avoids 401; get key at portal.jup.ag)
JUPITER_API_KEY=

# Optional: RPC for /api/wallet/balances and token-info fallback
SOLANA_RPC_URL=

# Optional: Total Users (unique connected wallets). Persist and real time on dashboard
# From Vercel Storage → KV or Upstash Redis
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: Redis (Vercel Redis or any Redis URL). Used for Total Users and Agent logs.
REDIS_URL=

# Optional: Helius. RPC and webhooks for whale/large transfer detection
# Get API key at helius.xyz; SOLANA_RPC_URL can be https://mainnet.helius-rpc.com/?api_key=YOUR_KEY
HELIUS_API_KEY=

# Optional: proxy POST /api/agent/chat to Express on your VPS (Claude + ANTHROPIC_API_KEY on the server).
# HTTPS origin only, no path. Example: https://api.yourdomain.com
# AGENT_BACKEND_ORIGIN=

# Command Center (browser: GET /api/config → Vercel rewrites to /api/health?mode=config; not VITE_*)
# BITQUERY_TOKEN=
# SHYFT_API_KEY=

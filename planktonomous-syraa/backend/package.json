{
  "name": "planktonomous-syraa-backend",
  "private": true,
  "version": "0.0.0",
  "description": "Planktonomous × Syraa VPS backend (Express + TypeScript + Prisma)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "apikey:create": "node dist/scripts/createApiKey.js",
    "test": "vitest run --config vitest.config.ts",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pm2": "^6.0.11",
    "pino-std-serializers": "^7.0.0",
    "uuid": "^11.1.0",
    "winston": "^3.18.3",
    "ws": "^8.18.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.18.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.16.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}


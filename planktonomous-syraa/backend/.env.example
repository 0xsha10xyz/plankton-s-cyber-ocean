# Server
NODE_ENV=production
PORT=3001
API_BASE_URL=https://your-vps-domain.com

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d
API_KEY_SECRET=

# Syraa API
SYRAA_API_BASE_URL=https://api.syraa.fun
SYRAA_API_KEY=
SYRAA_SIGNAL_ENDPOINT=/signal
SYRAA_INSIGHT_ENDPOINT=/v1/insight
SYRAA_TRACKING_ENDPOINT=/v1/tracking
SYRAA_CORBITS_ENDPOINT=/v1/corbits
SYRAA_NANSEN_ENDPOINT=/v1/nansen

# Planktonomous Agent
PLANKTONOMOUS_AGENT_URL=https://planktonomous.dev/launch-agent
PLANKTONOMOUS_API_KEY=

# Solana / X402 Payment
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_PRIVATE_KEY=
# Mainnet USDC mint
USDC_MINT_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
X402_SIGNAL_COST_USDC=0.0001

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/planktonomous_db

# Redis
REDIS_URL=redis://localhost:6379

# docker-compose (postgres/redis containers)
POSTGRES_USER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Scheduler
SIGNAL_POLL_INTERVAL_MINUTES=5
SIGNAL_CACHE_TTL_SECONDS=60

# Logging
LOG_LEVEL=info
LOG_FORMAT=json


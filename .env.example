# ─── Syraa Signal API ─────────────────────────────────────
# Host redirects http→https (301). Prefer https; code upgrades http→https for api.syraa.fun.
SIGNAL_API_URL=https://api.syraa.fun/signal

# ─── x402 Payment Config ──────────────────────────────────
# Choose: "solana", "base", or "both" (both chains need both wallet keys filled)
PAYMENT_NETWORK=both

# ─── Solana Wallet (if PAYMENT_NETWORK=solana) ────────────
# Base58-encoded private key of your payer wallet (must have USDC + SPL ATA for that USDC)
SOLANA_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
# Solana RPC (use Helius, QuickNode, or public RPC)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# USDC mint on Solana mainnet
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Payment recipient from x402 header
SOLANA_PAY_TO=53JhuF8bgxvUQ59nDG6kWs4awUQYCS3wswQmUsV5uC7t
SOLANA_FEE_PAYER=AepWpq3GQwL8CeKMtZyKtKPa7W91Coygh3ropAJapVdU

# ─── Base/EVM Wallet (if PAYMENT_NETWORK=base) ────────────
# Hex private key 0x...
EVM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Base mainnet RPC
EVM_RPC_URL=https://mainnet.base.org
# USDC contract on Base
EVM_USDC_ADDRESS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
# Payment recipient
EVM_PAY_TO=0xF9dcBFF7EdDd76c58412fd46f4160c96312ce734

# ─── Signal Query Params ──────────────────────────────────
SIGNAL_TOKEN=bitcoin
SIGNAL_SOURCE=binance
SIGNAL_INST_ID=BTCUSDT
SIGNAL_BAR=1h
SIGNAL_LIMIT=200

# ─── Agent Behavior ────────────────────────────────────────
# How often to poll for signals (in minutes)
POLL_INTERVAL_MINUTES=15
# Max USDC budget per request (in micro-USDC, 100000 = $0.10)
MAX_PAYMENT_AMOUNT=100000

# ─── Planktonomous ────────────────────────────────────────
# Set to 1 only if your Planktonomous endpoint accepts register/heartbeat POSTs
PLANKTONOMOUS_ENABLED=0
PLANKTONOMOUS_LAUNCH_URL=https://planktonomous.dev/launch-agent
# Add your Planktonomous API key if required
PLANKTONOMOUS_API_KEY=

# ─── Notifications (optional) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


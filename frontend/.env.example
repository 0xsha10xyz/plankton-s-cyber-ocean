# -----------------------------------------------------------------------------
# Local development
# -----------------------------------------------------------------------------
# Leave VITE_API_URL unset. Vite proxies /api to Express (vite.config.ts → port 3000).
# Run: npm run dev:backend from repo root alongside npm run dev

# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Production — choose ONE primary API strategy
# -----------------------------------------------------------------------------

# (A) Vercel same-origin API (Swap, market, Jupiter, /api/rpc) — RECOMMENDED for UI
#     Do NOT set VITE_API_URL. Deploy root `api/` serverless + set JUPITER_API_KEY, etc. on Vercel.
#     See docs/DEPLOYMENT.md

# (B) All /api/* on a VPS (Express backend)
#     Set VITE_API_URL to the API origin only, e.g.:
# VITE_API_URL=https://api.example.com

# (C) Hybrid: market on Vercel, agent on VPS — leave VITE_API_URL unset, then:
# VITE_AGENT_API_URL=https://api.example.com

# Optional Solana RPC for the wallet adapter (when not using /api/rpc same-origin)
# VITE_SOLANA_RPC_URL=

# Local dev: leave VITE_API_URL unset so the UI uses the Vite dev server origin and
# /api is proxied to Express (default http://127.0.0.1:3000). Override proxy target if needed:
# VITE_DEV_API_PROXY=http://127.0.0.1:3001
#
# Optional: point SPA at a remote API (Render, VPS, etc.). Use origin ONLY — no trailing /api or /api/jupiter
# VITE_API_URL=https://your-api.example.com

# Optional: Solana RPC. Use a dedicated RPC (e.g. Helius, QuickNode) for reliable swap execution
# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

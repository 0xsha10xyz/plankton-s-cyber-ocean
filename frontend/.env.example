# -----------------------------------------------------------------------------
# Local development (default)
# -----------------------------------------------------------------------------
# Leave VITE_API_URL unset. The Vite dev server proxies /api to Express (see vite.config.ts).
# Run the backend: npm run dev:backend (from repo root) — API at http://127.0.0.1:3000
#
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Production (Vercel static app + VPS API) — REQUIRED for a real deploy
# -----------------------------------------------------------------------------
# Set on Vercel (and rebuild). Point to your Express API origin only — no path suffix.
# Example: VITE_API_URL=https://api.example.com
#
# Without VITE_API_URL on a production HTTPS site, the UI will call same-origin /api/* on Vercel,
# which does not exist in the static-only setup (see docs/DEPLOYMENT.md).

# VITE_API_URL=https://api.example.com

# Optional: only if the agent is hosted on a different origin than VITE_API_URL (unusual).
# VITE_AGENT_API_URL=https://agent-api.example.com

# Optional: dedicated Solana RPC for the wallet adapter when not using the app’s /api/rpc proxy.
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

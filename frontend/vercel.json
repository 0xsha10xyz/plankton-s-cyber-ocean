{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/agent/(.*)",
      "dest": "https://api.planktonomous.dev/api/agent/$1"
    },
    {
      "src": "/api/usage/(.*)",
      "dest": "https://api.planktonomous.dev/api/usage/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

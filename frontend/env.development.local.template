# SECURITY:
# - Do NOT put PRIVY_APP_SECRET, X/Twitter OAuth secrets, or JWT keys in this file for client builds.
# - X OAuth credentials belong in the Privy Dashboard (Twitter integration), not in the repo.
# - See docs/privy-integration.md for X via Privy and credential handling.
# -----------------------------------------------------------------------------
VITE_PRIVY_APP_ID=
VITE_PRIVY_CLIENT_ID=

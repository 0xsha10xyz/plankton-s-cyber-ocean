{
  "name": "plankton-s-cyber-ocean",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo: frontend (Vite + React) and backend (Express + TypeScript)",
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:all": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "vercel-build": "node scripts/copy-dist.cjs",
    "preview": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=frontend",
    "agent:dev": "tsx src/agent.ts",
    "agent:build": "tsc -p tsconfig.agent.json",
    "agent:start": "node dist/agent.js"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "rimraf": "^5.0.5",
    "@solana/kit": "^6.8.0"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@scure/base": "^1.2.6",
    "@solana/kit": "^6.8.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "@upstash/redis": "^1.34.0",
    "@x402/core": "^2.0.0",
    "@x402/fetch": "^2.10.0",
    "@x402/svm": "^2.0.0",
    "axios": "^1.12.2",
    "dotenv": "^16.6.1",
    "node-cron": "^4.2.1",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

# Plankton API: copy to `.env` on the server (never commit `.env`)
# Example path on VPS: /opt/plankton-s-cyber-ocean/backend/.env

# --- API gateway (optional. External integrations; Express / VPS) ---
# Issue keys: POST /api/v1/admin/keys with header X-Gateway-Admin-Secret
# See docs/API_GATEWAY.md
GATEWAY_ADMIN_SECRET=
# Set to 0 to disable /api/v1 routes
# API_GATEWAY_ENABLED=1

# --- pay.sh compatibility proxy (optional; VPS) ---
# Makes Corbits x402 challenges detectable by pay.sh by injecting `WWW-Authenticate: x402` on 402 responses.
# Base Corbits proxy URL (no trailing slash):
# PAYSH_CORBITS_BASE_URL=https://<your-proxy>.api.corbits.dev
PAYSH_CORBITS_BASE_URL=
# Optional: if your Corbits proxy expects backend auth (rare; usually Corbits already adds auth to the backend).
# PAYSH_UPSTREAM_AUTH_HEADER=Authorization
# PAYSH_UPSTREAM_AUTH_VALUE=Bearer sk_prod_...
# PAYSH_UPSTREAM_AUTH_HEADER=
# PAYSH_UPSTREAM_AUTH_VALUE=

# --- Server (required on VPS) ---
PORT=3000

# Browser origins allowed to call this API (comma-separated, no spaces)
CORS_ORIGIN=https://yourdomain.com,https://your-app.vercel.app

# Do not set VERCEL on a raw VPS. Leave unset so Express binds to PORT.

# --- Total Users (same source as Vercel). Required for consistent dashboard counts ---
# Copy from Vercel / Environment Variables (exact same values):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Aliases also supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Or TCP connection:
# REDIS_URL=

# Optional baseline for display (default 109)
# STATS_BASELINE_COUNT=109

# --- Solana ---
SOLANA_RPC_URL=

# --- Market / chart ---
BIRDEYE_API_KEY=

# --- Jupiter ---
JUPITER_API_KEY=

# --- Nansen (on-chain intelligence; powers Dashboard "Tokens" tab) ---
# Server-side only. The browser MUST NOT receive this key. See docs/nansen-integration.md
# Get a key at https://www.nansen.ai (paid plan with API access)
NANSEN_API_KEY=

# --- Hive Protocol (optional; VPS only — proxied from Vercel via AGENT_BACKEND_ORIGIN) ---
# SDK: https://uphive.xyz/docs — register an agent and create an API key at https://uphive.xyz/agent/register
# Never expose HIVE_API_KEY to the browser; routes are under GET/POST /api/hive/* on this Express instance.
# HIVE_API_KEY=
# Optional — default https://uphive.xyz
# HIVE_API_BASE_URL=https://uphive.xyz

# --- OOBE Protocol (optional; phase 1 — VPS only) ---
# Readiness: GET /api/oobe/status and GET /api/oobe/probe (RPC balance check for agent wallet).
# Does not load the oobe-protocol npm SDK yet. Docs: https://oobe-protocol.gitbook.io/oobe-protocol
# Dedicated agent wallet (JSON byte array or base58 secret). Never commit real keys.
# OOBE_AGENT_PRIVATE_KEY=
# Optional public key if you do not want the server to derive it from the secret above.
# OOBE_AGENT_PUBKEY=
# OpenAI key for a future OOBE Core module (falls back to OPENAI_API_KEY when unset).
# OOBE_OPENAI_API_KEY=
# Optional OOBE platform key and Merkle seeds (for later on-chain memory).
# OOBE_KEY=
# OOBE_MERKLE_DB_SEED=
# OOBE_MERKLE_ROOT_SEED=
# Set OOBE_ENABLED=0 to report disabled even when keys are present.

# --- Agent chat (LLM on VPS) ---
# Claude (Anthropic). Set this on your VPS for Agent Chat. Tried first when the key is present.
# Create a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default model is claude-sonnet-4-6 (override for Haiku 4.5, Opus, etc.)
# ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
#
# Optional: use only Claude (no Groq/OpenAI fallback if Anthropic errors or rate limits).
# AGENT_ANTHROPIC_ONLY=1
#
# Groq. Free tier and fast (https://console.groq.com). Fallback unless AGENT_ANTHROPIC_ONLY=1
GROQ_API_KEY=
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile
#
# OpenAI (last fallback)
OPENAI_API_KEY=
# OPENAI_AGENT_MODEL=gpt-4o-mini

# --- Syraa Agent (server to server x402 paid fetch) ---
# Enables the assistant to fetch signals from https://api.syraa.fun/signal using server-funded payments.
# Provide at least ONE private key:
# - Solana (base58 secret key): pays on Solana mainnet USDC
# - EVM (hex private key): pays on Base mainnet USDC (fallback or primary)
#
# Optional: set SYRAA_TRY_EVM_FIRST=1 to prefer EVM when both keys exist.
# Optional: override API origin (default https://api.syraa.fun)
SYRAA_API_BASE_URL=https://api.syraa.fun
SYRAA_SOLANA_PRIVATE_KEY=
SYRAA_EVM_PRIVATE_KEY=
# SYRAA_TRY_EVM_FIRST=0

# --- HYRE DeFi (optional; server-paid x402, snapshots merged into Agent Chat) ---
# With HYRE_SOLANA_PRIVATE_KEY set, user messages that match TVL / yield / APR / DeFi keywords trigger a
# server-side GET to https://mpp.hyreagent.fun/defi/tvl or /defi/yields (paid upstream per HYRE pricing).
# HYRE_SOLANA_PRIVATE_KEY=   # Base58 Solana secret key — funds server-side x402 payments to HYRE (keep off-repo).
# HYRE_API_BASE_URL=https://mpp.hyreagent.fun
# HYRE_DEFI_CHAT=1          # Set to 0 to disable HYRE enrichment in chat while keeping other vars.
# HYRE_DEFI_LIMIT=15       # Max rows passed through to the LLM context (string query param to HYRE).
# HYRE_DEFI_CHAIN=all      # Chain filter for HYRE (e.g. all, solana, ethereum — see HYRE docs).

# --- Xona Solana Market (optional; server-paid x402, merged into Agent Chat when a mint is in context) ---
# POST https://api.xona-agent.com/token/solana-market — paid per action (~$0.01 USDC each). Uses x402 v2 like HYRE/Syraa.
# XONA_SOLANA_PRIVATE_KEY=   # Base58 Solana secret key — funds server-side x402 payments to Xona (keep off-repo).
# XONA_API_BASE_URL=https://api.xona-agent.com
# XONA_MARKET_CHAT=1         # Set to 0 to disable Xona enrichment while keeping the key.
# XONA_MARKET_MAX_ACTIONS=2 # Max actions per message (1–4). Each action is a separate paid request.
# XONA_MARKET_LIMIT=50       # Candle/trade row cap forwarded to Xona (10–120).
# XONA_MARKET_TAG_FILTER=   # Optional tag filter for whale_trades / holder_analysis when supported upstream.

# Optional: max age (ms) between client `usageTs` and server `Date.now()` for agent chat usage signatures (default 300000 = 5 min).
# USAGE_SIGNATURE_MAX_SKEW_MS=900000

# --- Agent chat: x402 (optional; block unlock via x402-solana + PayAI facilitator) ---
# Free agent chat: omit `X402_TREASURY_ADDRESS`, or force off paid chat while debugging:
# DISABLE_AGENT_CHAT_X402=1
# Order: (1) LLM keys work → (2) set treasury → (3) restart → (4) GET /api/agent/config shows x402AgentChat.enabled.
# Required to enable paid unlock (5 msgs per block on mainnet by default):
# X402_TREASURY_ADDRESS=
# Price per unlock (6 decimals). Default 100000 = $0.10 USDC if unset:
# X402_BLOCK_PRICE_ATOMIC=100000
# Mainnet USDC mint. Use canonical SPL USDC only. Known typos (same length): SSqm to SSqe; zybaPC to zybapC.
# EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# X402_USDC_MINT=
# Optional. Public origin for x402 `resource` URLs + x402scan discovery. Must match how clients reach this API
# (e.g. https://api.yourdomain.com if you register that host on x402scan — not the marketing apex unless API is there).
# Value is origin only (no path):
# X402_RESOURCE_BASE_URL=https://api.yourdomain.com
# X402_FACILITATOR_URL=https://facilitator.payai.network
# X402_NETWORK=solana
# Legacy alias (prefer X402_BLOCK_PRICE_ATOMIC): X402_CHAT_AMOUNT_ATOMIC=100000
# X402_PAYAI_API_KEY_ID=
# X402_PAYAI_API_KEY_SECRET=
# X402_SOLANA_RPC_URL=

# --- zauth / Vector (optional; domain verification for https://zauthx402.com/docs/vector) ---
# When set, GET /.well-known/vector-verify returns {"token":"..."} for platform-hosted verification (Vercel or this API origin).
# Paste the one-hour token from the Vector UI, deploy, complete verification, then clear or rotate after success.
# VECTOR_VERIFY_TOKEN=

# --- zauth Provider Hub SDK (optional; VPS Express only — monitors x402 on agent routes) ---
# API key from Provider Hub → SDK Integration. Never commit the real value.
# ZAUTH_API_KEY=
# Optional: `ZAUTH_API_ENDPOINT` if zauth gives you a custom backend URL (see SDK README).
# DISABLE_ZAUTH_SDK=1

# --- Helius (optional) ---
# HELIUS_API_KEY=

# --- Command Center (browser reads via GET /api/config on Vercel; local dev same route on this server) ---
# BITQUERY_TOKEN=
# SHYFT_API_KEY=

# --- Planktonomous Autopilot: Phase 1 (Polymarket data pipeline; no trading yet) ---
# PostgreSQL. Migrations run on API startup when set
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/plankton
# Optional Polymarket overrides (defaults: gamma-api, clob.polymarket.com, Goldsky PNL subgraph)
# POLY_API_KEY=
# POLY_GAMMA_BASE=https://gamma-api.polymarket.com
# POLY_CLOB_BASE=https://clob.polymarket.com
# POLY_SUBGRAPH_PNL_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/pnl-subgraph/0.0.14/gn
# PNL subgraph: deep skip/offset often times out on Goldsky; defaults cap skip & use smaller pages.
# POLY_WALLET_PAGE_SIZE=500
# POLY_WALLET_MAX_PAGES=8
# POLY_RECENCY_NEUTRAL=50
# AUTOPILOT_DATA_CRON=1
# AUTOPILOT_MARKETS_INTERVAL_MS=300000
# AUTOPILOT_WALLETS_INTERVAL_MS=14400000

# --- Planktonomous: Phases 2–5 (agent + execution + alerts). Fill when ready ---
# Claude (required for /api/autopilot/analyze and /api/agent/analyze)
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTOPILOT_MODEL=claude-sonnet-4-6
# Optional news context
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar
# Paper (default) vs live. Keep paper until you wire CLOB signing on the VPS
# AUTOPILOT_LIVE_TRADING=0
# Require EIP-191 signed body for analyze/control (set when going to production)
# AUTOPILOT_REQUIRE_VERIFY=0
# Platform-wide daily safety cap (%)
# AUTOPILOT_GLOBAL_MAX_DAILY_DRAWDOWN_PCT=5
# Trade rate limit (per wallet)
# AUTOPILOT_MAX_TRADES_PER_WINDOW=10
# AUTOPILOT_TRADE_WINDOW_MS=3600000
# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Plankton API — copy to `.env` on the VPS (never commit `.env`)
# Paste: nano /opt/plankton-s-cyber-ocean/backend/.env

# --- Server (wajib di VPS) ---
PORT=3000

# Browser origins allowed to call this API (comma-separated, no spaces)
CORS_ORIGIN=https://yourdomain.com,https://your-app.vercel.app

# Jangan set VERCEL di VPS — biarkan kosong supaya Express bind ke PORT.

# --- Total users (global, sama seperti Vercel) — wajib untuk angka konsisten ---
# Salin dari Vercel → Environment Variables (sama persis):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alias yang juga didukung:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Atau koneksi TCP:
# REDIS_URL=

# Baseline minimum tampilan (opsional, default 109)
# STATS_BASELINE_COUNT=109

# --- Solana ---
SOLANA_RPC_URL=

# --- Market / chart ---
BIRDEYE_API_KEY=

# --- Jupiter ---
JUPITER_API_KEY=

# --- Agent Chat (LLM di VPS saja) ---
# Groq = tier gratis & cepat (daftar di https://console.groq.com — tanpa kartu untuk mulai).
GROQ_API_KEY=
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile
#
# Anthropic Claude (prioritas pertama jika diset)
ANTHROPIC_API_KEY=
# ANTHROPIC_AGENT_MODEL=claude-3-5-haiku-20241022
#
# OpenAI (fallback terakhir)
OPENAI_API_KEY=
# OPENAI_AGENT_MODEL=gpt-4o-mini

# --- Helius (opsional) ---
# HELIUS_API_KEY=
